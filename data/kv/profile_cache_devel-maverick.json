        "pull_request": {
          "url": "https://api.github.com/repos/date-fns/date-fns/pulls/4113",
          "html_url": "https://github.com/date-fns/date-fns/pull/4113",
          "diff_url": "https://github.com/date-fns/date-fns/pull/4113.diff",
