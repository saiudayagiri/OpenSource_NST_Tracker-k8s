        "pull_request": {
          "url": "https://api.github.com/repos/testing-library/react-testing-library/pulls/1432",
          "html_url": "https://github.com/testing-library/react-testing-library/pull/1432",
          "diff_url": "https://github.com/testing-library/react-testing-library/pull/1432.diff",
