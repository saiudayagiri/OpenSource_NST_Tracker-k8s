# TEMPLATE ONLY — do not apply this file directly.
#
# Copy it, fill in real values, and apply THAT instead:
#
#   cp k8s/01-secret.yaml.example k8s/01-secret.yaml
#   # edit k8s/01-secret.yaml with real values
#   kubectl apply -f k8s/01-secret.yaml
#
# k8s/01-secret.yaml is gitignored — it will never be committed. This example
# file (with placeholder values) is the only one that's safe to commit.
#
# Values come from:
#   - GITHUB_TOKEN: a GitHub Personal Access Token (public_repo read scope is enough)
#   - ADMIN_PASSWORD: any password you choose for the /admin dashboard
#   - GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET: a GitHub OAuth App you register,
#     with callback URL https://oss-tracker.nstsdc.org/api/auth/github/callback
#   - CRON_SECRET: any random string — must match the secret used by
#     .github/workflows/refresh-cache.yml
#   - KV_REST_API_URL / KV_REST_API_TOKEN / KV_REST_API_READ_ONLY_TOKEN: from
#     YOUR OWN Upstash Redis database (upstash.com, free tier) — see
#     docs/DEPLOYMENT.md. Do not point this at the production Vercel database.
apiVersion: v1
kind: Secret
metadata:
  name: opensource-tracker-secrets
  namespace: opensource-tracker
type: Opaque
stringData:
  GITHUB_TOKEN: "ghp_replace_me"
  ADMIN_PASSWORD: "replace-me"
  GITHUB_CLIENT_ID: "replace_me"
  GITHUB_CLIENT_SECRET: "replace_me"
  CRON_SECRET: "replace_me"
  KV_REST_API_URL: "https://your-db-name.upstash.io"
  KV_REST_API_TOKEN: "replace_me"
  KV_REST_API_READ_ONLY_TOKEN: "replace_me"
